                <listApp>
                    <app loc="1" from="#w1">
                        <lem><expan><abbr>Fl</abbr><ex>avius</ex></expan></lem>
                        <rdg source="#lettich1983"><expan><abbr><choice><corr>F</corr><sic>E</sic></choice>l</abbr><ex>avius</ex></expan></rdg>
                    </app>
                    <app loc="1" from="#w2">
                        <lem><choice><reg>Augustus</reg><orig>Agustus</orig></choice></lem>
                        <rdg source="#bertolini1876a #bertolini1877">Augustus</rdg>
                    </app>
                    <app loc="2" from="#w3">
                        <lem>senioru<choice><corr>m</corr><sic>a</sic></choice></lem>
                        <rdg source="#bertolini1876a #bertolini1877 #cilv8737 #ilcv553 #hoffmann1963">seniorum</rdg>
                    </app>
                    <app loc="5" from="#w4">
                        <lem><expan><abbr>da</abbr><ex cert="low">bi</ex><abbr>t</abbr></expan></lem>
