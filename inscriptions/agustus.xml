                <ab>
                    <lb n="1"/><persName ref="#agustus"><w xml:id="w1"><expan><abbr>Fl</abbr><ex>avius</ex></expan></w> <w xml:id="w2"><choice><reg>Augustus</reg><orig>Agustus</orig></choice></w></persName>, de <choice><reg>numero</reg><orig>numeru</orig></choice>
                    <lb n="2"/>Mattiacoru<supplied reason="omitted">m</supplied> <w xml:id="w3">senioru<choice><corr>m</corr><sic>a</sic></choice></w>,
                    <lb n="3"/>emit sibi de <choice><reg>proprio</reg><orig>propio</orig></choice> suo <expan><abbr>ar</abbr><ex>cam</ex></expan>.
                    <lb n="4"/>Si quis eam <expan><abbr>ape</abbr><ex>rire</ex></expan> <expan><abbr>vo</abbr><ex>luerit</ex></expan>,
                    <lb n="5"/><w xml:id="w4"><expan><abbr>da</abbr><ex cert="low">bi</ex><abbr>t</abbr></expan></w> <w xml:id="w5"><expan><abbr>fi</abbr><ex>sci</ex></expan></w> <expan><abbr>vi</abbr><ex>ribus</ex></expan> <expan><abbr>argen</abbr><ex>ti</ex></expan> pon
                    <lb n="6" break="no"/><supplied reason="lost" evidence="previouseditor" source="#bertolini1876a #bertolini1877 #cilv8737"><measure type="fine" unit="roman_pound" commodity="silver" quantity="5">do <choice><reg>quinque</reg><orig>cinque</orig></choice></measure></supplied>.
                </ab>
            </div>
