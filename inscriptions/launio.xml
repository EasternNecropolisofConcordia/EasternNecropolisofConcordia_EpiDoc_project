                    <lb n="3" break="no"/><w xml:id="w6" prev="#w5">orum</w>, qui <choice><reg>vixit</reg><orig>vissit</orig></choice> <w xml:id="w7">an<supplied reason="omitted">n</supplied><choice><corr>i</corr><sic>u</sic></choice>s</w> <num value="40"><w xml:id="w8">XL</w></num>.
