                    <lb n="1"/><persName ref="#victurinus"><w xml:id="w1"><expan><abbr>Fla</abbr><ex>vius</ex></expan></w> <choice><reg>Victorinus</reg><orig>Victurinus</orig></choice></persName>, <w xml:id="w2"><expan><abbr>d</abbr><ex>e</ex></expan></w> <expan><abbr>n</abbr><ex>umero</ex></expan>
                    <lb n="2"/><choice><reg>Batavorum</reg><orig>Bataorum</orig></choice> seniorum,
                    <lb n="3"/>qui <w xml:id="w3">vix<surplus>s</surplus>it</w> <expan><abbr>an</abbr><ex>nos</ex></expan> <expan><abbr>p</abbr><ex>lus</ex></expan> <expan><abbr>m</abbr><ex>inus</ex></expan> <num value="35">XXXV</num>.
                    <lb n="4"/><w><supplied reason="lost" evidence="previouseditor" source="#bertolini1874a #bertolini1874b #cilv8761">E</supplied>m<supplied reason="omitted">p</supplied>ta</w> est ei arca de proprio
                    <lb n="5"/><supplied reason="lost" evidence="previouseditor" source="#bertolini1874a #bertolini1874b #cilv8761">la</supplied>bore<surplus>s</surplus> suo et qui eam a<unclear>r</unclear><supplied reason="lost" evidence="previouseditor" source="#bertolini1874a #bertolini1874b #cilv8761">ca<supplied reason="omitted">m</supplied></supplied>
                    <lb n="6"/><supplied reason="lost" evidence="previouseditor" source="#bertolini1874a #bertolini1874b #cilv8761">ape</supplied>rire vuluerit, iure ei <unclear>m</unclear><supplied reason="lost" evidence="previouseditor" source="#bertolini1875a #bertolini1875b #cilv8761">a</supplied>
