                    <lb n="8"/><supplied reason="lost" evidence="previouseditor" source="#bertolini1875a #bertolini1875b #cilv8761">infer</supplied>at <measure type="fine" unit="roman_pound" commodity="gold" quantity="1">auri <choice><reg>libram</reg><orig>libra</orig></choice> <choice><reg>unam</reg><orig>u<unclear>n</unclear><supplied reason="lost" evidence="previouseditor" source="#bertolini1875a #bertolini1875b #cilv8761">a</supplied></orig></choice></measure>.
